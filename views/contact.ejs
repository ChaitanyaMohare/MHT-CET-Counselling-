<%- include('partials/head') %>
<% const activePage = 'contact'; %>
<%- include('partials/navbar') %>

<div class="page-header">
  <h1>Ask For A Call</h1>
  <p>Connect with our experts instantly. Choose your preferred way to get help.</p>
</div>

<div class="contact-page-new">
  <div class="contact-options-container">
    
    <!-- Option 1: Request Callback -->
    <div class="contact-option-card">
      <div class="option-header">
        <div class="option-icon callback-icon">
          <img src="https://cdn-icons-png.flaticon.com/512/3059/3059502.png" alt="Call" />
        </div>
        <h2>Request a Callback</h2>
        <p>Schedule a call at your convenience</p>
      </div>

      <% if (success) { %>
        <div class="alert alert-success">
          <img src="https://cdn-icons-png.flaticon.com/512/5290/5290058.png" alt="Success" style="width:18px;height:18px;vertical-align:middle;margin-right:4px;" />
          Thank you! We'll call you at your preferred time.
        </div>
      <% } %>

      <% if (errors && errors.length > 0) { %>
        <div class="alert alert-error">
          <img src="https://cdn-icons-png.flaticon.com/512/1828/1828843.png" alt="Error" style="width:18px;height:18px;vertical-align:middle;margin-right:4px;" />
          <ul><% errors.forEach(e => { %><li><%= e %></li><% }); %></ul>
        </div>
      <% } %>

      <form action="/contact" method="POST" class="callback-form" novalidate>
        <div class="form-group-new">
          <label for="name">
            <img src="https://cdn-icons-png.flaticon.com/512/1077/1077114.png" alt="Name" class="input-icon" />
            Your Name
          </label>
          <input 
            type="text" 
            id="name"
            name="name" 
            value="<%= formData.name || '' %>" 
            placeholder="Enter your full name" 
            required 
            class="input-field"
          />
        </div>

        <div class="form-group-new">
          <label for="mobile">
            <img src="https://cdn-icons-png.flaticon.com/512/3059/3059502.png" alt="Mobile" class="input-icon" />
            Mobile Number
          </label>
          <input 
            type="tel" 
            id="mobile"
            name="mobile" 
            value="<%= formData.mobile || '' %>" 
            placeholder="10-digit mobile number" 
            pattern="[6-9][0-9]{9}"
            maxlength="10" 
            required 
            class="input-field"
          />
          <small class="input-hint">We'll call you on this number</small>
        </div>

        <div class="form-row-new">
          <div class="form-group-new">
            <label for="date">
              <img src="https://cdn-icons-png.flaticon.com/512/2838/2838779.png" alt="Date" class="input-icon" />
              Preferred Date
            </label>
            <input 
              type="date" 
              id="date"
              name="preferredDate" 
              value="<%= formData.preferredDate || '' %>" 
              min="<%= new Date().toISOString().split('T')[0] %>"
              required 
              class="input-field"
            />
          </div>

          <div class="form-group-new">
            <label for="time">
              <img src="https://cdn-icons-png.flaticon.com/512/2838/2838590.png" alt="Time" class="input-icon" />
              Preferred Time
            </label>
            <select 
              id="time"
              name="preferredTime" 
              required 
              class="input-field"
            >
              <option value="">Select time slot</option>
              <option value="10:00 AM - 12:00 PM">10:00 AM - 12:00 PM</option>
              <option value="12:00 PM - 2:00 PM">12:00 PM - 2:00 PM</option>
              <option value="2:00 PM - 4:00 PM">2:00 PM - 4:00 PM</option>
              <option value="4:00 PM - 6:00 PM">4:00 PM - 6:00 PM</option>
              <option value="6:00 PM - 8:00 PM">6:00 PM - 8:00 PM</option>
            </select>
          </div>
        </div>

        <button type="submit" class="submit-btn callback-btn">
          <img src="https://cdn-icons-png.flaticon.com/512/3059/3059502.png" alt="Call" style="width:20px;height:20px;filter:brightness(0) invert(1);" />
          Request Callback
        </button>
      </form>

      <div class="form-note">
        <img src="https://cdn-icons-png.flaticon.com/512/159/159469.png" alt="Secure" style="width:14px;height:14px;vertical-align:middle;margin-right:4px;" />
        We typically respond within 2-4 hours during business hours (10 AM - 6 PM)
      </div>
    </div>

    <!-- Divider with OR -->
    <div class="divider-section">
      <div class="divider-line"></div>
      <span class="divider-text">OR</span>
      <div class="divider-line"></div>
    </div>

    <!-- Option 2: WhatsApp Instant -->
    <div class="contact-option-card whatsapp-card">
      <div class="option-header">
        <div class="option-icon whatsapp-icon">
          <img src="https://cdn-icons-png.flaticon.com/512/733/733585.png" alt="WhatsApp" />
        </div>
        <h2>Chat on WhatsApp</h2>
        <p>Get instant response on WhatsApp</p>
      </div>

      <div class="whatsapp-info">
        <div class="whatsapp-feature">
          <img src="https://cdn-icons-png.flaticon.com/512/5290/5290058.png" alt="Check" class="feature-icon" />
          <span>Instant replies during business hours</span>
        </div>
        <div class="whatsapp-feature">
          <img src="https://cdn-icons-png.flaticon.com/512/5290/5290058.png" alt="Check" class="feature-icon" />
          <span>Share documents & screenshots easily</span>
        </div>
        <div class="whatsapp-feature">
          <img src="https://cdn-icons-png.flaticon.com/512/5290/5290058.png" alt="Check" class="feature-icon" />
          <span>Quick support for urgent queries</span>
        </div>
      </div>

      <a 
        href="https://wa.me/919529679073?text=Hi!%20I%20need%20help%20with%20MHT-CET%20counselling.%20Can%20you%20please%20assist%3F" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="submit-btn whatsapp-btn"
      >
        <img src="https://cdn-icons-png.flaticon.com/512/733/733585.png" alt="WhatsApp" style="width:22px;height:22px;filter:brightness(0) invert(1);" />
        Chat on WhatsApp
      </a>

      <div class="form-note">
        <img src="https://cdn-icons-png.flaticon.com/512/2838/2838590.png" alt="Hours" style="width:14px;height:14px;vertical-align:middle;margin-right:4px;" />
        Available: Monday - Saturday, 10:00 AM - 6:00 PM
      </div>
    </div>

  </div>

  <!-- Additional Contact Info -->
  <div class="additional-info">
    <h3>Other Ways to Reach Us</h3>
    <div class="info-grid">
      <div class="info-item">
        <img src="https://cdn-icons-png.flaticon.com/512/732/732200.png" alt="Email" />
        <div>
          <strong>Email Us</strong>
          <p>support@praveshmitra.in</p>
        </div>
      </div>
      <div class="info-item">
        <img src="https://cdn-icons-png.flaticon.com/512/3059/3059502.png" alt="Phone" />
        <div>
          <strong>Call Directly</strong>
          <p>+91 95296 79073</p>
        </div>
      </div>
      <div class="info-item">
        <img src="https://cdn-icons-png.flaticon.com/512/684/684908.png" alt="Location" />
        <div>
          <strong>Location</strong>
          <p>Pune, Maharashtra</p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
