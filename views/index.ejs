<script>
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

// Multi-select dropdown functionality
function toggleMultiSelect(id) {
  const dropdown = document.getElementById(id + 'Dropdown');
  const allDropdowns = document.querySelectorAll('.jf-multiselect-dropdown');
  
  // Close all other dropdowns
  allDropdowns.forEach(d => {
    if (d !== dropdown) {
      d.classList.remove('open');
    }
  });
  
  // Toggle current dropdown
  dropdown.classList.toggle('open');
}

function updateMultiSelectText(id) {
  const checkboxes = document.querySelectorAll(`#${id}Dropdown input[type="checkbox"]:checked`);
  const textEl = document.getElementById(id + 'Text');
  
  if (checkboxes.length === 0) {
    textEl.textContent = id === 'branches' ? 'Select Branches' : 'Select Cities';
    textEl.classList.remove('selected');
  } else if (checkboxes.length === 1) {
    textEl.textContent = checkboxes[0].value;
    textEl.classList.add('selected');
  } else {
    textEl.textContent = `${checkboxes.length} selected`;
    textEl.classList.add('selected');
  }
}

// Close dropdowns when clicking outside
document.addEventListener('click', function(event) {
  if (!event.target.closest('.jf-multiselect-wrapper')) {
    document.querySelectorAll('.jf-multiselect-dropdown').forEach(d => {
      d.classList.remove('open');
    });
  }
});

// Prevent form submission if no branches/cities selected
document.getElementById('heroForm')?.addEventListener('submit', function(e) {
  const branchesChecked = document.querySelectorAll('input[name="branches[]"]:checked').length;
  const citiesChecked = document.querySelectorAll('input[name="cities[]"]:checked').length;
  
  if (branchesChecked === 0) {
    e.preventDefault();
    alert('Please select at least one branch');
    return false;
  }
  
  if (citiesChecked === 0) {
    e.preventDefault();
    alert('Please select at least one city');
    return false;
  }
});
</script>


