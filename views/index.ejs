    <!-- Row 2: descriptions left, fan right -->
    <div class="fan-row fan-row-reverse">
      <div class="fan-desc-group">
        <div class="fan-desc-item">
          <div class="fan-desc-icon" style="background:#f3e8ff;"><img src="https://cdn-icons-png.flaticon.com/512/1584/1584892.png" alt="" /></div>
          <div><h4>Choice Filling Help</h4><p>Get expert support for CAP choice filling to maximise your admission chances.</p></div>
        </div>
        <div class="fan-desc-item">
          <div class="fan-desc-icon" style="background:#e0f7fa;"><img src="https://cdn-icons-png.flaticon.com/512/929/929574.png" alt="" /></div>
          <div><h4>Round Updates</h4><p>Real-time updates on CAP rounds, seat matrix, notifications &amp; important dates.</p></div>
        </div>
        <div class="fan-desc-item">
          <div class="fan-desc-icon" style="background:#e8eaf6;"><img src="https://cdn-icons-png.flaticon.com/512/942/942748.png" alt="" /></div>
          <div><h4>Secure &amp; Reliable</h4><p>Your data is 100% safe with us. We ensure privacy and build trust.</p></div>
        </div>
      </div>
      <div class="fan-container">
        <div data-text="Choice Filling" style="--r:-15;" class="fan-glass">
          <img src="https://cdn-icons-png.flaticon.com/512/1584/1584892.png" alt="" class="fan-icon-img" />
        </div>
        <div data-text="Round Updates" style="--r:5;" class="fan-glass">
          <img src="https://cdn-icons-png.flaticon.com/512/929/929574.png" alt="" class="fan-icon-img" />
        </div>
        <div data-text="Secure &amp; Safe" style="--r:25;" class="fan-glass">
          <img src="https://cdn-icons-png.flaticon.com/512/942/942748.png" alt="" class="fan-icon-img" />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     PACKAGES SECTION
════════════════════════════════════════════ -->
<section class="packages-section">
  <div class="section-container">
    <div class="section-heading">
      <h2>Choose Your Counselling Plan</h2>
      <p class="section-sub">Transparent pricing with detailed features. Select the plan that matches your needs.</p>
      <div class="heading-bar"></div>
    </div>
  </div>
  
  <div class="packages-grid">
    <% plans.forEach(function(plan) { %>
      <div class="plan-card <%= plan.featured ? 'featured' : '' %>">
        <% if (plan.badge) { %>
          <div class="featured-badge"><%= plan.badge %></div>
        <% } %>
        <div class="plan-name"><%= plan.name %> Plan</div>
        <% if (plan.subtitle) { %>
          <div class="plan-subtitle"><%= plan.subtitle %></div>
        <% } %>
        <div class="plan-price">
          <span class="currency">₹</span>
          <span class="amount"><%= plan.price.toLocaleString('en-IN') %></span>
          <span class="period">&nbsp;/ one-time</span>
        </div>
        <ul class="plan-features">
          <% plan.features.forEach(function(f) { %>
            <li><%= f %></li>
          <% }); %>
        </ul>
        <% if (plan.tagline) { %>
          <div class="plan-tagline"><%= plan.tagline %></div>
        <% } %>
        <a href="/register?plan=<%= plan.id %>" class="plan-select-btn">
          Select <%= plan.name %> Plan
        </a>
      </div>
    <% }); %>
  </div>

  <div style="text-align:center;margin-top:3rem;color:#64748b;font-size:0.85rem;">
    <p>
      <img src="https://cdn-icons-png.flaticon.com/512/159/159469.png" alt="Secure" style="width:16px;height:16px;vertical-align:middle;margin-right:4px;" />
      Your data is secure with us. &nbsp;|&nbsp; 
      <img src="https://cdn-icons-png.flaticon.com/512/1034/1034131.png" alt="Questions" style="width:16px;height:16px;vertical-align:middle;margin-right:4px;" />
      Questions? <a href="/contact" style="color:var(--blue);">Contact us</a>
    </p>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     COLLEGE SUGGESTION FORM
════════════════════════════════════════════ -->
<section class="suggestion-form-section" style="padding:4rem 2rem;background:#f0f4ff;">
  <div class="section-container">
    <div class="section-heading">
      <h2>Get Personalized College Suggestions</h2>
      <p class="section-sub">Fill the form below to receive expert guidance and counselling plans tailored to your preferences</p>
      <div class="heading-bar"></div>
    </div>

    <div class="suggestion-form-card" style="max-width:800px;margin:2rem auto;background:#fff;border-radius:16px;padding:3rem;box-shadow:0 10px 40px rgba(0,0,0,0.1);">
      
      <form id="suggestionForm" class="suggestion-form">
        
        <!-- Full Name -->
        <div class="form-group-new" style="margin-bottom:1.5rem;">
          <label style="display:block;margin-bottom:0.5rem;font-weight:600;color:var(--navy);">
            <img src="https://cdn-icons-png.flaticon.com/512/1077/1077114.png" alt="Name" style="width:16px;height:16px;vertical-align:middle;margin-right:6px;" />
            Full Name <span style="color:red;">*</span>
          </label>
          <input 
            type="text" 
            name="fullName" 
            id="suggestionFullName"
            class="input-field" 
            style="width:100%;padding:12px 16px;border:1.5px solid var(--border);border-radius:8px;font-size:1rem;"
            placeholder="Enter your full name" 
            required
          />
        </div>

        <!-- Mobile and Email Row -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
          <div class="form-group-new">
            <label style="display:block;margin-bottom:0.5rem;font-weight:600;color:var(--navy);">
              <img src="https://cdn-icons-png.flaticon.com/512/3059/3059502.png" alt="Mobile" style="width:16px;height:16px;vertical-align:middle;margin-right:6px;" />
              Mobile Number <span style="color:red;">*</span>
            </label>
            <input 
              type="tel" 
              name="mobileNo" 
              id="suggestionMobile"
              class="input-field" 
              style="width:100%;padding:12px 16px;border:1.5px solid var(--border);border-radius:8px;font-size:1rem;"
              placeholder="10-digit mobile" 
              pattern="[6-9][0-9]{9}"
              maxlength="10"
              required
            />
          </div>
          <div class="form-group-new">
            <label style="display:block;margin-bottom:0.5rem;font-weight:600;color:var(--navy);">
              <img src="https://cdn-icons-png.flaticon.com/512/732/732200.png" alt="Email" style="width:16px;height:16px;vertical-align:middle;margin-right:6px;" />
              Email Address <span style="color:red;">*</span>
            </label>
            <input 
              type="email" 
              name="email" 
              id="suggestionEmail"
              class="input-field" 
              style="width:100%;padding:12px 16px;border:1.5px solid var(--border);border-radius:8px;font-size:1rem;"
              placeholder="your.email@example.com" 
              required
            />
          </div>
        </div>

        <!-- MHT-CET and JEE Score Row -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
          <div class="form-group-new">
            <label style="display:block;margin-bottom:0.5rem;font-weight:600;color:var(--navy);">
              MHT-CET Score <span style="color:red;">*</span>
            </label>
            <input 
              type="number" 
              name="mhtCetScore" 
              id="suggestionMhtCet"
              class="input-field" 
              style="width:100%;padding:12px 16px;border:1.5px solid var(--border);border-radius:8px;font-size:1rem;"
              placeholder="0-100" 
              min="0" 
              max="100" 
              step="0.01"
              required
            />
          </div>
          <div class="form-group-new">
            <label style="display:block;margin-bottom:0.5rem;font-weight:600;color:var(--navy);">
              JEE Score (Optional)
            </label>
            <input 
              type="number" 
              name="jeeScore" 
              id="suggestionJee"
              class="input-field" 
              style="width:100%;padding:12px 16px;border:1.5px solid var(--border);border-radius:8px;font-size:1rem;"
              placeholder="0-100" 
              min="0" 
              max="100" 
              step="0.01"
            />
          </div>
        </div>

        <!-- Percentile Range -->
        <div class="form-group-new" style="margin-bottom:1.5rem;">
          <label style="display:block;margin-bottom:0.5rem;font-weight:600;color:var(--navy);">
            Document Type <span style="color:red;">*</span>
          </label>
          <select 
            name="percentileRange" 
            id="suggestionPercentile"
            class="input-field" 
            style="width:100%;padding:12px 16px;border:1.5px solid var(--border);border-radius:8px;font-size:1rem;"
            required
          >
            <option value="">Select Required Document</option>
            <option value="pune-below-50">PUNE Cut-off list Below 50%tile</option>
          </select>
          <small style="display:block;margin-top:0.5rem;color:#64748b;font-size:0.85rem;">Select the document you want to access</small>
        </div>

        <!-- Branches Multi-Select -->
        <div class="form-group-new" style="margin-bottom:1.5rem;">
          <label style="display:block;margin-bottom:0.5rem;font-weight:600;color:var(--navy);">
            Engineering Branches <span style="color:red;">*</span>
          </label>
          <div class="jf-multiselect-wrapper">
            <button type="button" class="jf-multiselect-trigger" onclick="toggleSuggestionMultiSelect('suggestionBranches')">
              <span class="jf-multiselect-text" id="suggestionBranchesText">Select Branches</span>
              <span class="jf-multiselect-arrow">▾</span>
            </button>
            <div class="jf-multiselect-dropdown" id="suggestionBranchesDropdown">
              <label class="jf-checkbox-label">
                <input type="checkbox" name="branches" value="Computer Engineering" onchange="updateSuggestionMultiSelectText('suggestionBranches')">
                <span>Computer Engineering</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="branches" value="Information Technology" onchange="updateSuggestionMultiSelectText('suggestionBranches')">
                <span>Information Technology</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="branches" value="Artificial Intelligence & Data Science" onchange="updateSuggestionMultiSelectText('suggestionBranches')">
                <span>Artificial Intelligence & Data Science</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="branches" value="Mechanical Engineering" onchange="updateSuggestionMultiSelectText('suggestionBranches')">
                <span>Mechanical Engineering</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="branches" value="Civil Engineering" onchange="updateSuggestionMultiSelectText('suggestionBranches')">
                <span>Civil Engineering</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="branches" value="Electronics & Telecommunication" onchange="updateSuggestionMultiSelectText('suggestionBranches')">
                <span>Electronics & Telecommunication</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="branches" value="Electrical Engineering" onchange="updateSuggestionMultiSelectText('suggestionBranches')">
                <span>Electrical Engineering</span>
              </label>
            </div>
          </div>
          <small style="display:block;margin-top:0.5rem;color:#64748b;font-size:0.85rem;">Select all branches you're interested in</small>
        </div>

        <!-- Cities Multi-Select -->
        <div class="form-group-new" style="margin-bottom:1.5rem;">
          <label style="display:block;margin-bottom:0.5rem;font-weight:600;color:var(--navy);">
            Preferred Cities <span style="color:red;">*</span>
          </label>
          <div class="jf-multiselect-wrapper">
            <button type="button" class="jf-multiselect-trigger" onclick="toggleSuggestionMultiSelect('suggestionCities')">
              <span class="jf-multiselect-text" id="suggestionCitiesText">Select Cities</span>
              <span class="jf-multiselect-arrow">▾</span>
            </button>
            <div class="jf-multiselect-dropdown" id="suggestionCitiesDropdown">
              <label class="jf-checkbox-label">
                <input type="checkbox" name="cities" value="Pune" onchange="updateSuggestionMultiSelectText('suggestionCities')">
                <span>Pune</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="cities" value="Mumbai" onchange="updateSuggestionMultiSelectText('suggestionCities')">
                <span>Mumbai</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="cities" value="Nagpur" onchange="updateSuggestionMultiSelectText('suggestionCities')">
                <span>Nagpur</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="cities" value="Nashik" onchange="updateSuggestionMultiSelectText('suggestionCities')">
                <span>Nashik</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="cities" value="Aurangabad" onchange="updateSuggestionMultiSelectText('suggestionCities')">
                <span>Aurangabad</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="cities" value="Thane" onchange="updateSuggestionMultiSelectText('suggestionCities')">
                <span>Thane</span>
              </label>
              <label class="jf-checkbox-label">
                <input type="checkbox" name="cities" value="Navi Mumbai" onchange="updateSuggestionMultiSelectText('suggestionCities')">
                <span>Navi Mumbai</span>
              </label>
            </div>
          </div>
          <small style="display:block;margin-top:0.5rem;color:#64748b;font-size:0.85rem;">Select all cities where you'd like to study</small>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="submit-btn jf-btn" style="width:100%;padding:16px;margin-top:1rem;">
          Get My Suggestions →
        </button>

        <!-- Success/Error Messages -->
