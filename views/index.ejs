      <div class="feature-card">
        <div class="feature-icon fi-orange">📈</div>
        <h4>Cutoff Insights</h4>
        <p>Access category-wise cutoffs for all branches from top engineering colleges.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon fi-purple">📋</div>
        <h4>Choice Filling Help</h4>
        <p>Get expert support for CAP choice filling to maximise your admission chances.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon fi-teal">🔔</div>
        <h4>Round Updates</h4>
        <p>Real-time updates on CAP rounds, seat matrix, notifications &amp; important dates.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon fi-navy">🛡️</div>
        <h4>Secure &amp; Reliable</h4>
        <p>Your data is 100% safe with us. We ensure privacy and build trust.</p>
      </div>
    </div>
  </div>
</section>

