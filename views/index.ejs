<%- include('partials/head') %>
<% const activePage = 'home'; %>
<%- include('partials/navbar') %>

<!-- ═══════════════════════════════════════════
     HERO SECTION
════════════════════════════════════════════ -->
<section class="hero2">
  <div class="hero2-container">

    <!-- Left -->
    <div class="hero2-left">
      <div class="hero2-badge">
        <span class="hero2-badge-dot"></span>
        #1 Platform for MHT-CET Aspirants
      </div>
      <h1 class="hero2-h1">
        कॉलेज तुमचं,<br>
        <span class="hero2-blue">जबाबदारी आमची!</span>
      </h1>
      <p class="hero2-sub">
        Get accurate college suggestions, cutoff insights,
        and expert guidance for MHT-CET admissions.
      </p>
      <div class="hero2-cta">
        <a href="/packages" class="btn2 btn2-primary">Get College Suggestions →</a>
        <a href="/packages" class="btn2 btn2-ghost">Explore Colleges</a>
      </div>
    </div>

    <!-- Center: student photo -->
    <div class="hero2-center">
      <img
        src="/images/hero-img.png"
        alt="MHT-CET Student"
        class="hero2-student-img"
      />
    </div>

    <!-- Right: Start Journey card -->
    <div class="hero2-right">
      <div class="journey-card">
        <h3 class="journey-title">Start Your Journey</h3>
        <p class="journey-sub">Quick form - Get instant college suggestions</p>
        <form action="/quick-lead" method="POST" class="journey-form" id="heroForm">
          
          <!-- Name -->
          <div class="jf-group">
            <input type="text" name="name" placeholder="Full Name" class="jf-input jf-compact" required aria-label="Full Name" />
          </div>

          <!-- Contact & Email in one row -->
          <div class="jf-row">
            <div class="jf-group jf-half">
              <input type="tel" name="contact" placeholder="Mobile No." class="jf-input jf-compact" pattern="[6-9][0-9]{9}" maxlength="10" required aria-label="Mobile Number" />
            </div>
            <div class="jf-group jf-half">
              <input type="email" name="email" placeholder="Email" class="jf-input jf-compact" required aria-label="Email Address" />
            </div>
          </div>

          <!-- MHT-CET & JEE Score in one row -->
          <div class="jf-row">
            <div class="jf-group jf-half">
              <input type="number" name="mhtCetScore" placeholder="MHT-CET Score" class="jf-input jf-compact" min="0" max="100" step="0.01" required aria-label="MHT-CET Score" />
            </div>
            <div class="jf-group jf-half">
              <input type="number" name="jeeScore" placeholder="JEE Score (Optional)" class="jf-input jf-compact" min="0" max="100" step="0.01" aria-label="JEE Score" />
            </div>
          </div>

          <!-- Branches Multi-Select -->
          <div class="jf-group">
            <div class="jf-multiselect-wrapper">
              <button type="button" class="jf-multiselect-trigger" onclick="toggleMultiSelect('branches')">
                <span class="jf-multiselect-text" id="branchesText">Select Branches</span>
                <span class="jf-multiselect-arrow">▾</span>
              </button>
              <div class="jf-multiselect-dropdown" id="branchesDropdown">
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="branches[]" value="Computer Science & IT" onchange="updateMultiSelectText('branches')" />
                  <span>Computer Science &amp; IT</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="branches[]" value="AI & Data Science" onchange="updateMultiSelectText('branches')" />
                  <span>AI &amp; Data Science</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="branches[]" value="Mechanical Engineering" onchange="updateMultiSelectText('branches')" />
                  <span>Mechanical Engineering</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="branches[]" value="Civil Engineering" onchange="updateMultiSelectText('branches')" />
                  <span>Civil Engineering</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="branches[]" value="Electronics (EXTC)" onchange="updateMultiSelectText('branches')" />
                  <span>Electronics (EXTC)</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="branches[]" value="Electrical Engineering" onchange="updateMultiSelectText('branches')" />
                  <span>Electrical Engineering</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="branches[]" value="Electronics & Telecom" onchange="updateMultiSelectText('branches')" />
                  <span>Electronics &amp; Telecom</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Cities Multi-Select -->
          <div class="jf-group">
            <div class="jf-multiselect-wrapper">
              <button type="button" class="jf-multiselect-trigger" onclick="toggleMultiSelect('cities')">
                <span class="jf-multiselect-text" id="citiesText">Select Cities</span>
                <span class="jf-multiselect-arrow">▾</span>
              </button>
              <div class="jf-multiselect-dropdown" id="citiesDropdown">
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Pune" onchange="updateMultiSelectText('cities')" />
                  <span>Pune</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Mumbai" onchange="updateMultiSelectText('cities')" />
                  <span>Mumbai</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Nagpur" onchange="updateMultiSelectText('cities')" />
                  <span>Nagpur</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Nashik" onchange="updateMultiSelectText('cities')" />
                  <span>Nashik</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="csn" onchange="updateMultiSelectText('cities')" />
                  <span>Chh. Sambhaji Nagar</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Thane" onchange="updateMultiSelectText('cities')" />
                  <span>Thane</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Navi Mumbai" onchange="updateMultiSelectText('cities')" />
                  <span>Navi Mumbai</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Kolhapur" onchange="updateMultiSelectText('cities')" />
                  <span>Kolhapur</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Solapur" onchange="updateMultiSelectText('cities')" />
                  <span>Solapur</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="Amravati" onchange="updateMultiSelectText('cities')" />
                  <span>Amravati</span>
                </label>
                <label class="jf-checkbox-label">
                  <input type="checkbox" name="cities[]" value="other" onchange="updateMultiSelectText('cities')" />
                  <span>Other</span>
                </label>
              </div>
            </div>
          </div>

          <button type="submit" class="jf-btn">Get My Suggestions</button>
        </form>
        <p class="journey-note">
          <img src="https://cdn-icons-png.flaticon.com/512/159/159469.png" alt="Secure" style="width:14px;height:14px;vertical-align:middle;margin-right:4px;" />
          Your data is safe with us.
        </p>
      </div>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════
     FEATURES GRID
════════════════════════════════════════════ -->
