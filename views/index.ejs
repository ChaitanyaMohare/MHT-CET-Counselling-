<script>
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

// Multi-select dropdown functionality
function toggleMultiSelect(id) {
  const dropdown = document.getElementById(id + 'Dropdown');
  const allDropdowns = document.querySelectorAll('.jf-multiselect-dropdown');
  
  // Close all other dropdowns
  allDropdowns.forEach(d => {
    if (d !== dropdown) {
      d.classList.remove('open');
    }
  });
  
  // Toggle current dropdown
  dropdown.classList.toggle('open');
}

function updateMultiSelectText(id) {
  const checkboxes = document.querySelectorAll(`#${id}Dropdown input[type="checkbox"]:checked`);
  const textEl = document.getElementById(id + 'Text');
  
  if (checkboxes.length === 0) {
    textEl.textContent = id === 'branches' ? 'Select Branches' : 'Select Cities';
    textEl.classList.remove('selected');
  } else if (checkboxes.length === 1) {
    textEl.textContent = checkboxes[0].value;
    textEl.classList.add('selected');
  } else {
    textEl.textContent = `${checkboxes.length} selected`;
    textEl.classList.add('selected');
  }
}

// Close dropdowns when clicking outside
document.addEventListener('click', function(event) {
  if (!event.target.closest('.jf-multiselect-wrapper')) {
    document.querySelectorAll('.jf-multiselect-dropdown').forEach(d => {
      d.classList.remove('open');
    });
  }
});

// Prevent form submission if no branches/cities selected
document.getElementById('heroForm')?.addEventListener('submit', function(e) {
  const branchesChecked = document.querySelectorAll('input[name="branches[]"]:checked').length;
  const citiesChecked = document.querySelectorAll('input[name="cities[]"]:checked').length;
  
  if (branchesChecked === 0) {
    e.preventDefault();
    alert('Please select at least one branch');
    return false;
  }
  
  if (citiesChecked === 0) {
    e.preventDefault();
    alert('Please select at least one city');
    return false;
  }
});

// Suggestion Form Multi-Select Functions
function toggleSuggestionMultiSelect(id) {
  const dropdown = document.getElementById(id + 'Dropdown');
  const allDropdowns = document.querySelectorAll('.jf-multiselect-dropdown');
  
  // Close all other dropdowns
  allDropdowns.forEach(d => {
    if (d !== dropdown) {
      d.classList.remove('open');
    }
  });
  
  // Toggle current dropdown
  dropdown.classList.toggle('open');
}

function updateSuggestionMultiSelectText(id) {
  const checkboxes = document.querySelectorAll(`#${id}Dropdown input[type="checkbox"]:checked`);
  const textEl = document.getElementById(id + 'Text');
  
  if (checkboxes.length === 0) {
    textEl.textContent = id === 'suggestionBranches' ? 'Select Branches' : 'Select Cities';
    textEl.classList.remove('selected');
  } else if (checkboxes.length === 1) {
    textEl.textContent = checkboxes[0].value;
    textEl.classList.add('selected');
  } else {
    textEl.textContent = `${checkboxes.length} selected`;
    textEl.classList.add('selected');
  }
}

// Suggestion Form Submission
document.getElementById('suggestionForm')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  
  const submitBtn = this.querySelector('.submit-btn');
  const successMsg = document.getElementById('suggestionSuccess');
  const errorMsg = document.getElementById('suggestionError');
  const errorText = document.getElementById('suggestionErrorText');
  
  // Hide messages
  successMsg.style.display = 'none';
  errorMsg.style.display = 'none';
  
  // Disable button
  submitBtn.disabled = true;
  submitBtn.textContent = 'Submitting...';
  
  // Get form data
  const formData = {
    fullName: document.getElementById('suggestionFullName').value.trim(),
    mobileNo: document.getElementById('suggestionMobile').value.trim(),
    email: document.getElementById('suggestionEmail').value.trim(),
    mhtCetScore: document.getElementById('suggestionMhtCet').value,
    jeeScore: document.getElementById('suggestionJee').value || null,
    percentileRange: document.getElementById('suggestionPercentile').value,
    branches: [],
    cities: []
  };
  
  // Get selected branches
  const branchCheckboxes = document.querySelectorAll('#suggestionBranchesDropdown input[type="checkbox"]:checked');
  branchCheckboxes.forEach(cb => formData.branches.push(cb.value));
  
  // Get selected cities
  const cityCheckboxes = document.querySelectorAll('#suggestionCitiesDropdown input[type="checkbox"]:checked');
  cityCheckboxes.forEach(cb => formData.cities.push(cb.value));
  
  // Validation
  if (formData.branches.length === 0) {
    errorText.textContent = 'Please select at least one branch';
    errorMsg.style.display = 'block';
    submitBtn.disabled = false;
    submitBtn.textContent = 'Get My Suggestions →';
    return;
  }
  
  if (formData.cities.length === 0) {
    errorText.textContent = 'Please select at least one city';
    errorMsg.style.display = 'block';
    submitBtn.disabled = false;
    submitBtn.textContent = 'Get My Suggestions →';
    return;
  }
  
  try {
    const response = await fetch('/api/suggestion-form', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(formData)
    });
    
    const result = await response.json();
    
    if (response.ok && result.success) {
      // Update success message with document link if available
      let successHTML = '<p style="margin:0;font-weight:600;">✓ Success! Check your email for college suggestions and counselling plans.</p>';
      
      if (result.documentLink && result.documentName) {
        successHTML += `
          <div style="margin-top:1rem;padding:1rem;background:#ffffff;border:2px solid #bbf7d0;border-radius:8px;">
            <p style="margin:0 0 0.5rem;font-weight:600;color:#166534;">📄 Your Document is Ready:</p>
            <a href="${result.documentLink}" target="_blank" rel="noopener noreferrer" 
               style="display:inline-block;background:#166534;color:#ffffff;padding:10px 20px;text-decoration:none;border-radius:6px;font-weight:600;margin-top:0.5rem;">
              📥 View ${result.documentName}
            </a>
            <p style="margin:0.5rem 0 0;font-size:0.85rem;color:#166534;">
              <em>Document link is also sent to your email</em>
            </p>
          </div>
        `;
      }
      
      successMsg.innerHTML = successHTML;
      successMsg.style.display = 'block';
      successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      
      // Reset form
      document.getElementById('suggestionForm').reset();
      updateSuggestionMultiSelectText('suggestionBranches');
      updateSuggestionMultiSelectText('suggestionCities');
      
      // Hide success after 15 seconds (longer to allow viewing document link)
      setTimeout(() => {
        successMsg.style.display = 'none';
      }, 15000);
    } else {
      errorText.textContent = result.message || 'Something went wrong. Please try again.';
      errorMsg.style.display = 'block';
      errorMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  } catch (error) {
    console.error('Error:', error);
    errorText.textContent = 'Network error. Please check your connection and try again.';
    errorMsg.style.display = 'block';
    errorMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  } finally {
    submitBtn.disabled = false;
    submitBtn.textContent = 'Get My Suggestions →';
  }
});

// Mobile number validation for suggestion form
document.getElementById('suggestionMobile')?.addEventListener('input', function(e) {
  this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
});

// Score validation for suggestion form
document.getElementById('suggestionMhtCet')?.addEventListener('input', function(e) {
  if (parseFloat(this.value) > 100) {
    this.value = 100;
  }
});

document.getElementById('suggestionJee')?.addEventListener('input', function(e) {
  if (parseFloat(this.value) > 100) {
    this.value = 100;
  }
});
</script>


