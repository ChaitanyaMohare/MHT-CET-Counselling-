<!-- ═══════════════════════════════════════════
     HERO SECTION
════════════════════════════════════════════ -->
<section class="hero2">
  <div class="hero2-container">

    <!-- Left -->
    <div class="hero2-left">
      <div class="hero2-badge">
        <span class="hero2-badge-dot"></span>
        #1 Platform for MHT-CET Aspirants
      </div>
      <h1 class="hero2-h1">
        Right College.<br>
        Right Branch.<br>
        <span class="hero2-blue">Bright Future.</span>
      </h1>
      <p class="hero2-sub">
        Get accurate college suggestions, cutoff insights,
        and expert guidance for MHT-CET admissions.
      </p>
      <div class="hero2-cta">
        <a href="/packages" class="btn2 btn2-primary">Get College Suggestions →</a>
        <a href="/packages" class="btn2 btn2-ghost">Explore Colleges</a>
      </div>
      <div class="hero2-trust">
        <div class="trust2-item"><span class="trust2-icon">✅</span> Trusted by<br><strong>10,000+ Students</strong></div>
        <div class="trust2-item"><span class="trust2-icon">📊</span> Up-to-date<br><strong>Cutoff Data</strong></div>
        <div class="trust2-item"><span class="trust2-icon">🎯</span> Personalized<br><strong>Guidance</strong></div>
        <div class="trust2-item"><span class="trust2-icon">🔒</span> 100% Secure<br><strong>&amp; Confidential</strong></div>
      </div>
    </div>

    <!-- Center: student photo -->
    <div class="hero2-center">
      <img
        src="https://images.unsplash.com/photo-1529390079861-591de354faf5?q=85&w=700&auto=format&fit=crop&crop=top"
        alt="MHT-CET Student"
        class="hero2-student-img"
      />
    </div>

    <!-- Right: Start Journey card -->
    <div class="hero2-right">
      <div class="journey-card">
        <h3 class="journey-title">Start Your Journey</h3>
        <p class="journey-sub">Enter your details to get personalised college suggestions</p>
        <form action="/packages" method="GET" class="journey-form">
          <div class="jf-group">
            <input type="number" placeholder="Enter MHT-CET Percentile" min="0" max="100" step="0.01" class="jf-input" />
            <span class="jf-icon">🎯</span>
          </div>
          <div class="jf-group">
            <select class="jf-input">
              <option value="">Select Category</option>
              <option>General (Open)</option>
              <option>OBC</option>
              <option>SC</option>
              <option>ST</option>
              <option>NT</option>
              <option>EWS</option>
              <option>VJ-DT</option>
            </select>
          </div>
          <div class="jf-group">
            <select class="jf-input">
              <option value="">Select Preferred Branch</option>
              <option>Computer Science &amp; IT</option>
              <option>Mechanical Engineering</option>
              <option>Civil Engineering</option>
              <option>Electronics (EXTC)</option>
              <option>AI &amp; Data Science</option>
            </select>
          </div>
          <div class="jf-group">
            <select class="jf-input">
              <option value="">Select Preferred Region</option>
              <option>Pune</option>
              <option>Mumbai</option>
              <option>Nagpur</option>
              <option>Nashik</option>
              <option>Aurangabad</option>
            </select>
          </div>
          <button type="submit" class="jf-btn">Get My Suggestions →</button>
        </form>
        <p class="journey-note">🔒 Your data is safe with us. We never share your information.</p>
      </div>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════
