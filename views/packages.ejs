<%- include('partials/head') %>
<% const activePage = 'packages'; %>
<%- include('partials/navbar') %>

<div class="page-header">
  <h1>Choose Your Counselling Plan</h1>
  <p>Transparent pricing with detailed features. Select the plan that matches your needs.</p>
</div>

<section class="packages-section">
  <div class="packages-grid">
    <% plans.forEach(function(plan) { %>
      <div class="plan-card <%= plan.featured ? 'featured' : '' %>">
        <% if (plan.badge) { %>
          <div class="featured-badge"><%= plan.badge %></div>
        <% } %>
        <div class="plan-name"><%= plan.name %> Plan</div>
        <% if (plan.subtitle) { %>
          <div class="plan-subtitle"><%= plan.subtitle %></div>
        <% } %>
        <div class="plan-price">
          <span class="currency">₹</span>
          <span class="amount"><%= plan.price.toLocaleString('en-IN') %></span>
          <span class="period">&nbsp;/ one-time</span>
        </div>
        <ul class="plan-features">
          <% plan.features.forEach(function(f) { %>
            <li><%= f %></li>
          <% }); %>
        </ul>
        <% if (plan.tagline) { %>
          <div class="plan-tagline"><%= plan.tagline %></div>
        <% } %>
        <% if (plan.cashfreeLink) { %>
          <a href="<%= plan.cashfreeLink %>" target="_blank" rel="noopener noreferrer" class="plan-select-btn">
            Select <%= plan.name %> Plan
          </a>
        <% } else { %>
          <form action="/select-plan" method="POST">
            <input type="hidden" name="plan" value="<%= plan.id %>" />
            <button type="submit" class="plan-select-btn">Select <%= plan.name %> Plan</button>
          </form>
        <% } %>
      </div>
    <% }); %>
  </div>

  <div style="text-align:center;margin-top:3rem;color:#64748b;font-size:0.85rem;">
    <p>
      <img src="https://cdn-icons-png.flaticon.com/512/159/159469.png" alt="Secure" style="width:16px;height:16px;vertical-align:middle;margin-right:4px;" />
      Secure payment powered by Cashfree. &nbsp;|&nbsp; 
      <img src="https://cdn-icons-png.flaticon.com/512/1034/1034131.png" alt="Questions" style="width:16px;height:16px;vertical-align:middle;margin-right:4px;" />
      Questions? <a href="/contact" style="color:var(--blue);">Contact us</a>
    </p>
  </div>
</section>

<%- include('partials/footer') %>

