<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div style="min-height:calc(100vh - 64px);display:flex;align-items:center;justify-content:center;padding:3rem 2rem;background:linear-gradient(135deg,#f0f4ff,#e8f0fe);">
  <div style="max-width:560px;width:100%;text-align:center;">

    <!-- Success Icon -->
    <div style="width:100px;height:100px;background:linear-gradient(135deg,#22c55e,#16a34a);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2.8rem;margin:0 auto 2rem;box-shadow:0 12px 40px rgba(34,197,94,0.3);animation:bounceIn 0.6s;">
      ✅
    </div>

    <h1 style="font-size:2rem;font-weight:900;color:var(--navy);margin-bottom:0.75rem;">
      Thank You for Applying!
    </h1>
    <p style="font-size:1rem;color:var(--muted);line-height:1.75;margin-bottom:2rem;">
      We have received your registration, <strong style="color:var(--navy);"><%= student ? student.firstName : 'Student' %></strong>!<br/>
      Our expert counsellor will call you within <strong style="color:var(--blue2);">24 hours</strong> to discuss your college preferences and guide you through the counselling process.
    </p>

    <!-- Info Card -->
    <div style="background:#fff;border-radius:16px;box-shadow:0 4px 24px rgba(26,86,219,0.08);padding:1.75rem 2rem;margin-bottom:2rem;text-align:left;border:1.5px solid var(--border);">
      <div style="font-size:0.75rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:1.2rem;">Your Registration Summary</div>
      <% if (student) { %>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div><div style="font-size:0.72rem;color:var(--muted);font-weight:600;text-transform:uppercase;">Name</div><div style="font-weight:700;color:var(--navy);margin-top:2px;"><%= student.firstName %> <%= student.lastName %></div></div>
        <div><div style="font-size:0.72rem;color:var(--muted);font-weight:600;text-transform:uppercase;">Mobile</div><div style="font-weight:700;color:var(--navy);margin-top:2px;"><%= student.mobile %></div></div>
        <div><div style="font-size:0.72rem;color:var(--muted);font-weight:600;text-transform:uppercase;">CET Percentile</div><div style="font-weight:700;color:var(--blue2);font-size:1.1rem;margin-top:2px;"><%= student.cetPercentile %>%ile</div></div>
        <div><div style="font-size:0.72rem;color:var(--muted);font-weight:600;text-transform:uppercase;">Plan</div><div style="font-weight:700;color:var(--navy);margin-top:2px;"><%= student.selectedPlan %> — ₹<%= student.planAmount ? student.planAmount.toLocaleString('en-IN') : '' %></div></div>
        <div><div style="font-size:0.72rem;color:var(--muted);font-weight:600;text-transform:uppercase;">Category</div><div style="font-weight:700;color:var(--navy);margin-top:2px;"><%= student.category %></div></div>
        <div><div style="font-size:0.72rem;color:var(--muted);font-weight:600;text-transform:uppercase;">Payment</div><div style="font-weight:700;color:#16a34a;margin-top:2px;">✅ Confirmed</div></div>
      </div>
      <% } %>
    </div>

    <!-- What happens next -->
    <div style="background:linear-gradient(135deg,rgba(26,86,219,0.06),rgba(124,58,237,0.06));border:1.5px solid rgba(26,86,219,0.15);border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:2rem;text-align:left;">
      <div style="font-weight:700;color:var(--navy);margin-bottom:0.75rem;font-size:0.9rem;">📋 What happens next?</div>
      <div style="display:flex;flex-direction:column;gap:0.6rem;">
        <div style="display:flex;gap:10px;font-size:0.85rem;color:var(--text);">
          <span style="color:var(--blue2);font-weight:700;flex-shrink:0;">1.</span> Our counsellor will call you on <strong><%= student ? student.mobile : 'your registered number' %></strong>
        </div>
        <div style="display:flex;gap:10px;font-size:0.85rem;color:var(--text);">
          <span style="color:var(--blue2);font-weight:700;flex-shrink:0;">2.</span> We'll discuss your college &amp; branch preferences over the call
        </div>
        <div style="display:flex;gap:10px;font-size:0.85rem;color:var(--text);">
          <span style="color:var(--blue2);font-weight:700;flex-shrink:0;">3.</span> You'll receive a personalised college report within 48 hours
        </div>
      </div>
    </div>

    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/" class="btn2 btn2-ghost">← Back to Home</a>
      <a href="https://wa.me/919529679073?text=Hi%2C%20I%20have%20registered%20for%20MHT-CET%20counselling.%20My%20name%20is%20<%= student ? encodeURIComponent(student.firstName + ' ' + student.lastName) : '' %>%20and%20mobile%20is%20<%= student ? student.mobile : '' %>."
         target="_blank"
         class="btn2 btn2-primary" style="background:#25D366;box-shadow:0 4px 16px rgba(37,211,102,0.35);">
        💬 Chat on WhatsApp
      </a>
    </div>

  </div>
</div>

<style>
@keyframes bounceIn { 0%{transform:scale(0)} 60%{transform:scale(1.1)} 100%{transform:scale(1)} }
@media(max-width:480px){ div[style*="grid-template-columns:1fr 1fr"]{grid-template-columns:1fr !important;} }
</style>

<%- include('partials/footer') %>
